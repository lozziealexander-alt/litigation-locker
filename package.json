{
  "name": "litigation-locker",
  "version": "1.0.0",
  "description": "Litigation case management vault",
  "main": "src/main/index.js",
  "scripts": {
    "bundle": "esbuild src/renderer/index.jsx --bundle --outfile=src/renderer/bundle.js --platform=browser --target=chrome120 --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "npm run bundle && electron .",
    "dev": "npm run bundle && electron . --dev",
    "build": "npm run bundle && electron-builder",
    "publish": "npm run bundle && electron-builder --publish always",
    "build:web": "node scripts/build-web-viewer.js",
    "build:web:vault": "node scripts/build-web-viewer.js --vault"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "chrono-node": "^2.9.0",
    "exif-reader": "^2.0.3",
    "mailparser": "^3.9.3",
    "mime-types": "^3.0.2",
    "natural": "^8.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.litigation-locker.app",
    "productName": "Litigation Locker",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "bundled-vault/",
        "to": "bundled-vault/",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "lozziealexander-alt",
      "repo": "litigation-locker",
      "private": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ws": "^8.19.0"
  }
}
